# The default docker-compose.yaml works out of the box with no .env file.
# These variables are only needed if you want to override the defaults
# (e.g., connecting to an external InfluxDB instead of the bundled one).

# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_TOKEN=your-token
# INFLUXDB_ORG=your-org
# INFLUXDB_BUCKET=tokens
